---
interface Props {
    title: string;
    description: string;
    href: string;
}

const { href, title, description } = Astro.props;
---

<li class="link-card">
    <div class="card-content">
        <h2>{title}</h2>
        <p class="description">{description}</p>
        <a href={href} class="button">
            Explore cache
            <i class="fa-solid fa-arrow-right"></i>
        </a>
    </div>
</li>
<style>
    .link-card {
        list-style: none;
        display: flex;
        position: relative;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: transform 0.2s, box-shadow 0.2s;
        overflow: hidden;
    }
    .link-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(180deg, rgb(var(--accent)), rgb(var(--accent-dark)));
        transition: width 0.2s;
    }
    .card-content {
        padding: 1.5rem 2rem;
        display: flex;
        flex: 1;
        flex-direction: column;
        gap: 0.75rem;
    }
    h2 {
        margin: 0;
        font-size: 1.35rem;
        color: rgb(var(--accent-dark));
    }
    .description {
        margin: 0;
        font-size: 0.95rem;
        color: #666;
        line-height: 1.5;
    }
    .button {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1rem;
        background: rgb(var(--accent-dark));
        color: white;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        margin-top: auto;
        align-self: flex-start;
        transition: opacity 0.2s;
    }
    .link-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
    .link-card:hover::before {
        width: 6px;
    }
    .button:hover {
        opacity: 0.9;
    }
</style>
