---
interface Props {
    title: string;
    description: string;
    href: string;
}

const { href, title, description } = Astro.props;
---

<li class="link-card">
    <div class="card-content">
        <h2>{title}</h2>
        <p class="description">{description}</p>
        <a href={href} class="button">
            Explore cache
            <i class="fa-solid fa-arrow-right"></i>
        </a>
    </div>
</li>
